      <button class="online-toggle" onclick="toggleOnline(this)" id="onlineBtn">
        <div class="toggle-dot online" id="onlineDot"></div>
        <span id="onlineText">Online</span>
      </button>
    </div>
    <div class="stats-row">
      <div class="stat-box"><div class="stat-num">₹2,400</div><div class="stat-label">Today</div></div>
      <div class="stat-box"><div class="stat-num">3</div><div class="stat-label">Jobs Done</div></div>
      <div class="stat-box"><div class="stat-num">4.8⭐</div><div class="stat-label">Rating</div></div>
    </div>
  </div><div class="has-bottom-nav" style="overflow-y:auto;">
    <div class="section">
      <div class="section-title">New Requests 🔔</div>
      <div id="jobRequests">
        <div class="job-card fade-in">
          <div class="job-card-header">
            <div>
              <div class="job-customer">Priya Mehta</div>
              <div class="job-service">⚡ Electrical Repair</div>
            </div>
            <span class="badge badge-orange">New</span>
          </div>
          <div class="job-details">
            <span>📍 Sector 12, Badlapur</span>
            <span>📅 Today 3:00 PM</span>
            <span>💰 ₹400-600</span>
          </div>
          <div style="font-size:13px;color:var(--text-light)">Ceiling fan not working, needs immediate repair</div>
          <div class="job-actions">
            <button class="btn-accept" onclick="acceptJob(this)">✅ Accept</button>
            <button class="btn-decline" onclick="declineJob(this)">✗ Decline</button>
          </div>
        </div>
        <div class="job-card fade-in">
          <div class="job-card-header">
            <div>
              <div class="job-customer">Amit Verma</div>
              <div class="job-service">⚡ Wiring Work</div>
            </div>
            <span class="badge badge-orange">New</span>
          </div>
          <div class="job-details">
            <span>📍 Station Road, Badlapur</span>
            <span>📅 Tomorrow 11:00 AM</span>
            <span>💰 ₹800-1200</span>
          </div>
          <div style="font-size:13px;color:var(--text-light)">New room wiring for 2 BHK flat</div>
          <div class="job-actions">
            <button class="btn-accept" onclick="acceptJob(this)">✅ Accept</button>
            <button class="btn-decline" onclick="declineJob(this)">✗ Decline</button>
          </div>
        </div>
      </div>

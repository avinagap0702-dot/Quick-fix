  </div><div class="bottom-nav">
    <button class="nav-item active">
      <span class="nav-icon">📋</span>Jobs
    </button>
    <button class="nav-item">
      <span class="nav-icon">💰</span>Earnings
    </button>
    <button class="nav-item">
      <span class="nav-icon">👤</span>Profile
    </button>
  </div>
</div><script>
// ===== DATA =====
const vendors = [
  { id:1, name:"Rajesh Kumar", trade:"Electrician", emoji:"⚡", rating:4.9, jobs:142, price:"₹300/hr", area:"Badlapur", available:true },
  { id:2, name:"Suresh Patil", trade:"Plumber", emoji:"🔧", rating:4.7, jobs:98, price:"₹250/hr", area:"Ambernath", available:true },
  { id:3, name:"Anil Sharma", trade:"Painter", emoji:"🎨", rating:4.8, jobs:67, price:"₹400/hr", area:"Badlapur", available:false },
  { id:4, name:"Manoj Yadav", trade:"Carpenter", emoji:"🪚", rating:4.6, jobs:55, price:"₹350/hr", area:"Badlapur", available:true },
  { id:5, name:"Deepak Singh", trade:"Cleaner", emoji:"🧹", rating:4.5, jobs:200, price:"₹200/hr", area:"Ulhasnagar", available:true },
  { id:6, name:"Vikram Nair", trade:"AC Repair", emoji:"❄️", rating:4.9, jobs:88, price:"₹500/hr", area:"Badlapur", available:true },
  { id:7, name:"Santosh More", trade:"Electrician", emoji:"⚡", rating:4.7, jobs:110, price:"₹280/hr", area:"Ambernath", available:false },
  { id:8, name:"Ganesh Pawar", trade:"Plumber", emoji:"🔧", rating:4.8, jobs:76, price:"₹270/hr", area:"Badlapur", available:true },
];

let selectedVendor = null;
let selectedSlot = null;
let currentFilter = 'all';
let isOnline = true;

// ===== INIT =====
setTimeout(() => { showScreen('roleSelect'); }, 2000);

function showScreen(id) {
  document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
  document.getElementById(id).classList.add('active');
}

function goCustomerHome() {
  renderVendors(vendors);
  showScreen('customerHome');
}

// ===== VENDORS =====
function renderVendors(list) {
  const container = document.getElementById('vendorList');
  if (!list.length) {
    container.innerHTML = '<div class="text-center text-muted" style="padding:30px">No vendors found 😔</div>';
    return;
  }
  container.innerHTML = list.map(v => `
    <div class="vendor-card fade-in" onclick="openBooking(${v.id})">
      <div class="vendor-avatar">${v.emoji}</div>
      <div class="vendor-info">
        <div class="vendor-name">${v.name}</div>
        <div class="vendor-trade">${v.trade}</div>
        <div class="vendor-meta">
          <span class="vendor-rating"><span>⭐</span> ${v.rating} · ${v.jobs} jobs</span>
          <span class="badge ${v.available ? 'badge-green' : 'badge-orange'}">${v.available ? 'Available' : 'Busy'}</span>
        </div>
      </div>
      <div class="vendor-price">${v.price}</div>
    </div>
  `).join('');
}

function selectCat(el, cat) {
  document.querySelectorAll('.cat-item').forEach(c => c.classList.remove('selected'));
  el.classList.add('selected');
  currentFilter = cat;
  filterVendors('');
}

function filterVendors(query) {
  let filtered = vendors;
  if (currentFilter !== 'all') filtered = filtered.filter(v => v.trade === currentFilter);
  if (query) filtered = filtered.filter(v =>
    v.name.toLowerCase().includes(query.toLowerCase()) ||
    v.trade.toLowerCase().includes(query.toLowerCase())
  );
  renderVendors(filtered);
}

// ===== BOOKING =====
function openBooking(id) {
  selectedVendor = vendors.find(v => v.id === id);
  const info = document.getElementById('bookingVendorInfo');
  info.innerHTML = `
    <div class="booking-avatar">${selectedVendor.emoji}</div>
    <div>
      <div class="booking-vname">${selectedVendor.name}</div>
      <div class="booking-vtrade">${selectedVendor.trade}</div>
      <div class="booking-vrating">⭐ ${selectedVendor.rating} · ${selectedVendor.jobs} jobs done · ${selectedVendor.price}</div>
    </div>
  `;
  // set min date to today
  document.getElementById('bookingDate').min = new Date().toISOString().split('T')[0];
  selectedSlot = null;
  document.querySelectorAll('.time-slot').forEach(s => s.classList.remove('selected'));
  showScreen('bookingScreen');
}

function selectSlot(el) {
  document.querySelectorAll('.time-slot').forEach(s => s.classList.remove('selected'));
  el.classList.add('selected');
  selectedSlot = el.textContent;
}

function confirmBooking() {
  const addr = document.getElementById('bookingAddress').value.trim();
  const date = document.getElementById('bookingDate').value;
  if (!addr) { alert('Please enter your address!'); return; }
  if (!date) { alert('Please select a date!'); return; }
  if (!selectedSlot) { alert('Please select a time slot!'); return; }

  const details = document.getElementById('successDetails');
  details.innerHTML = `
    <div class="success-card-row"><span>👷 Provider</span><span>${selectedVendor.name}</span></div>
    <div class="success-card-row"><span>🛠️ Service</span><span>${selectedVendor.trade}</span></div>
    <div class="success-card-row"><span>📅 Date</span><span>${date}</span></div>
    <div class="success-card-row"><span>⏰ Time</span><span>${selectedSlot}</span></div>
    <div class="success-card-row"><span>📍 Address</span><span style="max-width:150px;text-align:right">${addr}</span></div>
    <div class="success-card-row"><span>💰 Rate</span><span>${selectedVendor.price}</span></div>
  `;
  showScreen('successScreen');
}

// ===== VENDOR REGISTER =====
function selectTrade(el) {
  document.querySelectorAll('.trade-item').forEach(t => t.classList.remove('selected'));
  el.classList.add('selected');
}

function registerVendor() {
  const name = document.getElementById('vName').value.trim();
  const phone = document.getElementById('vPhone').value.trim();
  const trade = document.querySelector('.trade-item.selected .trade-name')?.textContent;
  const rate = document.getElementById('vRate').value;
  const area = document.getElementById('vArea').value.trim();

  if (!name || !phone) { alert('Please fill name and phone!'); return; }

  document.getElementById('vHeaderName').textContent = name;
  document.getElementById('vHeaderTrade').textContent =
    (document.querySelector('.trade-item.selected .trade-emoji')?.textContent || '🔧') + ' ' + trade;

  showScreen('vendorHome');
}

// ===== VENDOR ACTIONS =====
function toggleOnline(btn) {
  isOnline = !isOnline;
  const dot = document.getElementById('onlineDot');
  const txt = document.getElementById('onlineText');
  dot.classList.toggle('online', isOnline);
  txt.textContent = isOnline ? 'Online' : 'Offline';
}

function acceptJob(btn) {
  const card = btn.closest('.job-card');
  const name = card.querySelector('.job-customer').textContent;
  card.querySelector('.job-actions').innerHTML = `<div style="text-align:center;width:100%;color:var(--success);font-weight:700;font-size:14px;padding:8px">✅ Accepted — Contact ${name}</div>`;
  card.style.borderLeft = '4px solid var(--success)';
}

function declineJob(btn) {
  const card = btn.closest('.job-card');
  card.style.opacity = '0';
  card.style.transition = 'opacity 0.3s';
  setTimeout(() => card.remove(), 300);
}

function switchTab(tab, el) {
  document.querySelectorAll('.bottom-nav .nav-item').forEach(n => n.classList.remove('active'));
  el.classList.add('active');
}

// Init vendors
renderVendors(vendors);
</script></body>
</html>
